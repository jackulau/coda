{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Coda",
  "version": "2.0.0-alpha.0",
  "identifier": "io.coda.desktop",
  "build": {
    "beforeDevCommand": "bun --cwd ../../app run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun --cwd ../../app run build",
    "frontendDist": "../../app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Coda",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 720,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: https://api.github.com http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi", "nsis", "deb", "rpm", "appimage"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"],
    "macOS": {
      "signingIdentity": null,
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "12.0",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "tsp": false,
      "webviewInstallMode": { "type": "embedBootstrapper" },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
