{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Coda",
  "version": "2.0.0-alpha.0",
  "identifier": "io.coda.desktop",
  "build": {
    "beforeDevCommand": "bun --cwd ../../app run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun --cwd ../../app run build",
    "frontendDist": "../../app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Coda",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 720,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: https://api.github.com http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"]
  }
}
